{
  "name": "soft-white",
  "desc": "A soft, clean white theme with warm coral accents",
  "i18nkey": "theme.appearance.preset.softWhite",
  "version": "1.0.0",
  "themeScheme": "light",
  "grayscale": false,
  "colourWeakness": false,
  "recommendColor": false,
  "themeColor": "#FF6B6B",
  "otherColor": {
    "info": "#2080f0",
    "success": "#52c41a",
    "warning": "#faad14",
    "error": "#f5222d"
  },
  "themeRadius": 4,
  "isInfoFollowPrimary": true,
  "layout": {
    "mode": "vertical",
    "scrollMode": "content"
  },
  "page": {
    "animate": true,
    "animateMode": "fade-slide"
  },
  "header": {
    "height": 52,
    "breadcrumb": {
      "visible": true,
      "showIcon": true
    },
    "multilingual": {
      "visible": true
    },
    "globalSearch": {
      "visible": true
    }
  },
  "tab": {
    "visible": true,
    "cache": true,
    "height": 40,
    "mode": "chrome",
    "closeTabByMiddleClick": false
  },
  "fixedHeaderAndTab": true,
  "sider": {
    "inverted": false,
    "width": 200,
    "collapsedWidth": 64,
    "mixWidth": 90,
    "mixCollapsedWidth": 64,
    "mixChildMenuWidth": 200,
    "autoSelectFirstMenu": false
  },
  "footer": {
    "visible": true,
    "fixed": false,
    "height": 44,
    "right": true
  },
  "watermark": {
    "visible": false,
    "text": "SoybeanAdmin",
    "enableUserName": false,
    "enableTime": false,
    "timeFormat": "YYYY-MM-DD HH:mm"
  },
  "tokens": {
    "light": {
      "colors": {
        "container": "rgb(252, 252, 254)",
        "layout": "rgb(248, 249, 251)",
        "inverted": "rgb(40, 40, 44)",
        "base-text": "rgb(48, 48, 51)"
      },
      "boxShadow": {
        "header": "0 1px 2px rgb(0, 0, 0, 0.04)",
        "sider": "1px 0 4px 0 rgb(0, 0, 0, 0.03)",
        "tab": "0 1px 2px rgb(0, 0, 0, 0.04)"
      }
    },
    "dark": {
      "colors": {
        "container": "rgb(28, 28, 30)",
        "layout": "rgb(22, 22, 24)",
        "base-text": "rgb(224, 224, 226)"
      }
    }
  }
}
